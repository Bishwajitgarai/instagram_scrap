{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60,
        "memory": 1024
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "env": {
    "PLAYWRIGHT_BROWSERS_PATH": "./pw-browsers",
    "HEADLESS": "True",
    "PYTHON_VERSION": "3.12"
  }
}
